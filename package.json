{
  "name": "bluebubbles-api",
  "version": "1.0.0",
  "description": "iMessage REST API wrapper for BlueBubbles",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
