    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
