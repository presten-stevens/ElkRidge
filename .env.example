# =============================================================================
# BlueBubbles iMessage API - Environment Configuration
# =============================================================================
# Copy this file and rename per instance: cp .env.example .env.tyler_iphone
# All variables with defaults shown can be omitted (defaults apply).
# =============================================================================

# --- BlueBubbles Connection ---
# URL of the BlueBubbles server REST API (required)
BLUEBUBBLES_URL=http://localhost:1234
# BlueBubbles server password (required)
BLUEBUBBLES_PASSWORD=your-bb-password-here

# --- Server ---
# Port the Express server listens on
PORT=3000
# Environment mode: development | production | test
NODE_ENV=development
# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Enable human-readable log output (disable in production for JSON logs)
ENABLE_PRETTY_LOGS=true

# --- Phone Normalization ---
# ISO 3166-1 alpha-2 country code for phone number normalization
DEFAULT_COUNTRY_CODE=US

# --- API Authentication ---
# Bearer token for API access (required in production, min 16 characters)
API_KEY=your-api-key-min-16-chars

# --- Webhooks ---
# URL to POST inbound message payloads to (optional)
CRM_WEBHOOK_URL=
# URL to POST downtime alert payloads to (optional)
ALERT_WEBHOOK_URL=

# --- Rate Limiting ---
# Token bucket capacity for rate limiting
RATE_LIMIT_CAPACITY=100
# Tokens refilled per hour
RATE_LIMIT_REFILL_PER_HOUR=4

# --- Webhook Retry ---
# Max entries in webhook retry queue
RETRY_QUEUE_MAX_SIZE=1000

# --- Health Monitoring ---
# Health check polling interval in ms
HEALTH_POLL_INTERVAL_MS=60000
# Consecutive health failures before alerting
ALERT_AFTER_FAILURES=2
